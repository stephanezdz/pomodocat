{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PomodoCat",
  "version": "0.1.0",
  "identifier": "com.pomellacat.pomodocat",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "PomodoCat",
        "width": 980,
        "height": 720,
        "minWidth": 880,
        "minHeight": 620,
        "center": true,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "transparent": false,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$HOME/Library/Application Support/PomodoCat/cats/**",
          "$APPDATA/PomodoCat/cats/**",
          "$HOME/.config/PomodoCat/cats/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png"
    ],
    "macOS": {
      "minimumSystemVersion": "13.0"
    },
    "category": "public.app-category.productivity"
  }
}
